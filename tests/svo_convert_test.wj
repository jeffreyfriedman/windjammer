// TDD Test: Windjammer Octree SVO (DOGFOODING!)
// 
// Tests for proper hierarchical sparse voxel octree structure
// Using Windjammer's native @test framework

use windjammer_app::voxel::VoxelGrid
use windjammer_app::voxel::svo_convert::voxelgrid_to_svo_flat

const LEAF_FLAG: u32 = 0x100

// Helper: Decode SVO node
fn decode_node(node: u32) -> (u8, bool, u32) {
    let material = (node & 0xFF) as u8
    let is_leaf = (node & LEAF_FLAG) != 0
    let child_ptr = node >> 9
    (material, is_leaf, child_ptr)
}

@test
fn test_empty_grid_creates_empty_octree() {
    let grid = VoxelGrid::new(8, 8, 8)
    let svo = voxelgrid_to_svo_flat(grid)
    
    assert_eq!(svo.len(), 1, "Empty grid should have 1 node")
    
    let (material, is_leaf, _) = decode_node(svo[0])
    assert(is_leaf, "Root should be leaf for empty grid")
    assert_eq!(material, 0, "Empty grid should have material 0")
}

@test
fn test_single_voxel_creates_path_to_leaf() {
    let mut grid = VoxelGrid::new(8, 8, 8)
    grid.set(4, 4, 4, 5)  // Single voxel at center
    
    let svo = voxelgrid_to_svo_flat(grid)
    
    // Root should be interior node (not homogeneous)
    let (_, is_leaf, child_ptr) = decode_node(svo[0])
    assert(!is_leaf, "Root should be interior node for single voxel")
    assert(child_ptr > 0, "Root should have valid child pointer")
    
    println!("[test] Single voxel test: {} nodes generated", svo.len())
}

@test
fn test_octree_respects_octant_ordering() {
    let mut grid = VoxelGrid::new(8, 8, 8)
    grid.set(0, 0, 0, 1)  // Octant 0: (-x, -y, -z)
    grid.set(4, 0, 0, 2)  // Octant 1: (+x, -y, -z)
    
    let svo = voxelgrid_to_svo_flat(grid)
    
    let (_, is_leaf, _) = decode_node(svo[0])
    assert(!is_leaf, "Root should be interior for multiple voxels")
    
    println!("[test] Octant ordering test: {} nodes generated", svo.len())
}

@test
fn test_homogeneous_regions_collapse() {
    let mut grid = VoxelGrid::new(8, 8, 8)
    
    // Fill 2x2x2 region with same material
    for x in 0..2 {
        for y in 0..2 {
            for z in 0..2 {
                grid.set(x, y, z, 5)
            }
        }
    }
    
    let svo = voxelgrid_to_svo_flat(grid)
    
    // Should be more compact than 8 leaf nodes
    println!("[test] Homogeneous collapse: {} nodes for 8 voxels", svo.len())
    assert(svo.len() < 20, "Homogeneous regions should collapse")
}
