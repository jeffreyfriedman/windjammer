// From regression/bug_self_subfield_copy_read_test.rs `test_let_binding_copy_subfield...`
struct InnerPanel {
    width: int,
    height: int,
    name: string,
}

struct OuterPanel {
    inner: InnerPanel,
    count: int,
}

impl OuterPanel {
    fn compute_area(self) -> int {
        let w = self.inner.width
        let h = self.inner.height
        w * h
    }
}

pub fn test_nested_copy_fields_for_area() {
    let layout = OuterPanel {
        inner: InnerPanel {
            width: 6,
            height: 7,
            name: "wall".to_string(),
        },
        count: 0,
    }
    assert_eq(layout.compute_area(), 42)
}
