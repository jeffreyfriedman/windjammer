// PBR Mesh Rendering Shader (Vertex + Fragment)
//
// Standard metallic-roughness PBR workflow for traditional triangle meshes.
// Outputs to the mesh color/depth buffers for compositing with voxels
// via mesh_voxel_composite.wjsl.
//
// Vertex layout:
//   position (vec3<f32>)
//   normal   (vec3<f32>)
//   tangent  (vec4<f32>) — xyz = tangent, w = handedness
//   uv       (vec2<f32>)
//
// Skinned variant adds:
//   bone_indices (vec4<u32>)
//   bone_weights (vec4<f32>)

struct CameraUniforms {
    view: mat4x4<f32>,
    proj: mat4x4<f32>,
    view_proj: mat4x4<f32>,
    inv_view: mat4x4<f32>,
    camera_pos: vec3<f32>,
    _pad0: f32,
}

struct ModelUniforms {
    model: mat4x4<f32>,
    normal_matrix: mat4x4<f32>,
}

struct MaterialUniforms {
    albedo: vec4<f32>,
    emissive: vec3<f32>,
    metallic: f32,
    roughness: f32,
    normal_scale: f32,
    occlusion_strength: f32,
    alpha_cutoff: f32,
}

struct LightUniforms {
    sun_direction: vec3<f32>,
    _pad0: f32,
    sun_color: vec3<f32>,
    sun_intensity: f32,
    ambient_color: vec3<f32>,
    ambient_intensity: f32,
}

@group(0) @binding(0) var<uniform> camera: CameraUniforms;
@group(1) @binding(0) var<uniform> model: ModelUniforms;
@group(2) @binding(0) var<uniform> material: MaterialUniforms;
@group(2) @binding(1) var albedo_texture: texture_2d<f32>;
@group(2) @binding(2) var normal_texture: texture_2d<f32>;
@group(2) @binding(3) var mr_texture: texture_2d<f32>;
@group(2) @binding(4) var emissive_texture: texture_2d<f32>;
@group(2) @binding(5) var linear_sampler: sampler;
@group(3) @binding(0) var<uniform> light: LightUniforms;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) normal: vec3<f32>,
    @location(2) tangent: vec4<f32>,
    @location(3) uv: vec2<f32>,
}

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) world_position: vec3<f32>,
    @location(1) world_normal: vec3<f32>,
    @location(2) world_tangent: vec4<f32>,
    @location(3) uv: vec2<f32>,
}

// === Vertex Shader ===

@vertex
fn vs_main(in: VertexInput) -> VertexOutput {
    var out: VertexOutput;

    let world_pos = model.model * vec4<f32>(in.position, 1.0);
    out.clip_position = camera.view_proj * world_pos;
    out.world_position = world_pos.xyz;

    out.world_normal = normalize((model.normal_matrix * vec4<f32>(in.normal, 0.0)).xyz);

    let world_tangent_dir = normalize((model.model * vec4<f32>(in.tangent.xyz, 0.0)).xyz);
    out.world_tangent = vec4<f32>(world_tangent_dir, in.tangent.w);

    out.uv = in.uv;

    return out;
}

// === PBR Functions ===

const PI: f32 = 3.14159265359;

fn distribution_ggx(n_dot_h: f32, roughness: f32) -> f32 {
    let a = roughness * roughness;
    let a2 = a * a;
    let nh2 = n_dot_h * n_dot_h;
    let denom = nh2 * (a2 - 1.0) + 1.0;
    return a2 / (PI * denom * denom);
}

fn geometry_schlick_ggx(n_dot_v: f32, roughness: f32) -> f32 {
    let k = (roughness + 1.0) * (roughness + 1.0) / 8.0;
    return n_dot_v / (n_dot_v * (1.0 - k) + k);
}

fn geometry_smith(n_dot_v: f32, n_dot_l: f32, roughness: f32) -> f32 {
    return geometry_schlick_ggx(n_dot_v, roughness) * geometry_schlick_ggx(n_dot_l, roughness);
}

fn fresnel_schlick(cos_theta: f32, f0: vec3<f32>) -> vec3<f32> {
    return f0 + (1.0 - f0) * pow(clamp(1.0 - cos_theta, 0.0, 1.0), 5.0);
}

fn get_normal_from_map(world_normal: vec3<f32>, world_tangent: vec4<f32>, uv: vec2<f32>) -> vec3<f32> {
    let tangent_normal = textureSample(normal_texture, linear_sampler, uv).xyz * 2.0 - 1.0;
    let N = normalize(world_normal);
    let T = normalize(world_tangent.xyz);
    let B = cross(N, T) * world_tangent.w;
    let TBN = mat3x3<f32>(T, B, N);
    return normalize(TBN * (tangent_normal * vec3<f32>(material.normal_scale, material.normal_scale, 1.0)));
}

fn tonemap_aces(color: vec3<f32>) -> vec3<f32> {
    let a = 2.51;
    let b = 0.03;
    let c = 2.43;
    let d = 0.59;
    let e = 0.14;
    return clamp((color * (a * color + b)) / (color * (c * color + d) + e), vec3<f32>(0.0), vec3<f32>(1.0));
}

// === Fragment Shader ===

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // Sample textures (fall back to uniform values)
    var albedo = material.albedo;
    let tex_color = textureSample(albedo_texture, linear_sampler, in.uv);
    if tex_color.a > 0.01 {
        albedo = tex_color * material.albedo;
    }

    // Alpha test
    if albedo.a < material.alpha_cutoff {
        discard;
    }

    // Metallic-roughness from texture or uniform
    var metallic = material.metallic;
    var roughness = material.roughness;
    let mr_sample = textureSample(mr_texture, linear_sampler, in.uv);
    if mr_sample.b > 0.001 || mr_sample.g > 0.001 {
        metallic = mr_sample.b;
        roughness = mr_sample.g;
    }
    roughness = clamp(roughness, 0.04, 1.0);

    // Normal mapping
    var N = normalize(in.world_normal);
    let normal_sample = textureSample(normal_texture, linear_sampler, in.uv);
    if normal_sample.a > 0.01 {
        N = get_normal_from_map(in.world_normal, in.world_tangent, in.uv);
    }

    let V = normalize(camera.camera_pos - in.world_position);
    let L = normalize(-light.sun_direction);
    let H = normalize(V + L);

    let n_dot_v = max(dot(N, V), 0.001);
    let n_dot_l = max(dot(N, L), 0.0);
    let n_dot_h = max(dot(N, H), 0.0);
    let v_dot_h = max(dot(V, H), 0.0);

    // F0: 0.04 for dielectrics, albedo for metals
    let f0 = mix(vec3<f32>(0.04), albedo.rgb, metallic);

    // Cook-Torrance BRDF
    let D = distribution_ggx(n_dot_h, roughness);
    let G = geometry_smith(n_dot_v, n_dot_l, roughness);
    let F = fresnel_schlick(v_dot_h, f0);

    let numerator = D * G * F;
    let denominator = 4.0 * n_dot_v * n_dot_l + 0.0001;
    let specular = numerator / denominator;

    let kd = (vec3<f32>(1.0) - F) * (1.0 - metallic);
    let diffuse = kd * albedo.rgb / PI;

    let radiance = light.sun_color * light.sun_intensity;
    var lo = (diffuse + specular) * radiance * n_dot_l;

    // Ambient
    let ambient = light.ambient_color * light.ambient_intensity * albedo.rgb;
    lo = lo + ambient;

    // Emissive
    var emissive_sample = textureSample(emissive_texture, linear_sampler, in.uv).rgb;
    let emissive = material.emissive + emissive_sample;
    lo = lo + emissive;

    // Tonemap
    let mapped = tonemap_aces(lo);

    // sRGB
    let gamma = pow(mapped, vec3<f32>(1.0 / 2.2));

    return vec4<f32>(gamma, albedo.a);
}
