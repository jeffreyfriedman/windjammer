// Temporal Anti-Aliasing + Upscaling Compute Shader (WJSL)
//
// Combines sub-pixel jitter resolve with temporal accumulation and
// velocity-based history reprojection. Uses neighborhood clamping
// (YCoCg color space) to reject ghosting.
// Workgroup: 8x8 threads (64 total)

struct UpscaleParams {
    src_width: u32,
    src_height: u32,
    dst_width: u32,
    dst_height: u32,
    render_scale: f32,
    sharpness: f32,
    frame_count: u32,
    blend_factor: f32,
    jitter_x: f32,
    jitter_y: f32,
    prev_jitter_x: f32,
    prev_jitter_y: f32,
}

struct CameraData {
    view_matrix: mat4x4<f32>,
    proj_matrix: mat4x4<f32>,
    inv_view: mat4x4<f32>,
    inv_proj: mat4x4<f32>,
    position: vec3<f32>,
    _pad0: f32,
    screen_width: f32,
    screen_height: f32,
    near_plane: f32,
    far_plane: f32,
}

struct LightData {
    sun_dir: vec3<f32>,
    _pad0: f32,
    sun_color: vec3<f32>,
    sun_intensity: f32,
    sky_color: vec3<f32>,
    _pad1: f32,
    ground_color: vec3<f32>,
    ambient_intensity: f32,
    gi_samples: u32,
    gi_intensity: f32,
    frame_count: u32,
    _pad2: f32,
    prev_vp_matrix: mat4x4<f32>,
    temporal_blend: f32,
    _pad3: f32,
    _pad4: f32,
    _pad5: f32,
    camera_pos: vec3<f32>,
    _pad6: f32,
}

@group(0) @binding(0) uniform params: UpscaleParams;
@group(0) @binding(1) storage read input_color: array<vec4<f32>>;
@group(0) @binding(2) storage read_write output_color: array<vec4<f32>>;
@group(0) @binding(3) storage read history_color: array<vec4<f32>>;
@group(0) @binding(4) storage read gbuffer_depth: array<f32>;
@group(0) @binding(5) uniform camera: CameraData;
@group(0) @binding(6) uniform light: LightData;

fn rgb_to_ycocg(rgb: vec3<f32>) -> vec3<f32> {
    let co = rgb.r - rgb.b;
    let tmp = rgb.b + co * 0.5;
    let cg = rgb.g - tmp;
    let y = tmp + cg * 0.5;
    return vec3(y, co, cg);
}

fn ycocg_to_rgb(ycocg: vec3<f32>) -> vec3<f32> {
    let tmp = ycocg.x - ycocg.z * 0.5;
    let g = ycocg.z + tmp;
    let b = tmp - ycocg.y * 0.5;
    let r = ycocg.y + b;
    return vec3(r, g, b);
}

fn linearize_depth(raw_depth: f32, near: f32, far: f32) -> f32 {
    if raw_depth >= 1.0 { return far; }
    return near * far / (far - raw_depth * (far - near));
}

fn world_pos_from_depth(pixel_x: u32, pixel_y: u32, depth: f32, width: u32, height: u32) -> vec3<f32> {
    let ndc_x = (f32(pixel_x) + 0.5) / f32(width) * 2.0 - 1.0;
    let ndc_y = 1.0 - (f32(pixel_y) + 0.5) / f32(height) * 2.0;
    let clip = vec4(ndc_x, ndc_y, depth, 1.0);
    let view_pos = camera.inv_proj * clip;
    let view_pos3 = view_pos.xyz / view_pos.w;
    let world = camera.inv_view * vec4(view_pos3, 1.0);
    return world.xyz;
}

fn compute_motion_vector(pixel_x: u32, pixel_y: u32, depth: f32, width: u32, height: u32) -> vec2<f32> {
    let world_pos = world_pos_from_depth(pixel_x, pixel_y, depth, width, height);
    let prev_clip = light.prev_vp_matrix * vec4(world_pos, 1.0);
    let prev_ndc = prev_clip.xyz / prev_clip.w;
    let prev_uv = vec2((prev_ndc.x + 1.0) * 0.5, (1.0 - prev_ndc.y) * 0.5);
    let curr_uv = vec2(
        (f32(pixel_x) + 0.5) / f32(width),
        (f32(pixel_y) + 0.5) / f32(height)
    );
    return prev_uv - curr_uv;
}

fn fetch_prefiltered(px: u32, py: u32, w: u32, h: u32) -> vec4<f32> {
    let cx = min(px, w - 1u);
    let cy = min(py, h - 1u);
    let c = input_color[cy * w + cx];
    if (cy == 0u || cy >= h - 1u) {
        return c;
    }
    let above = input_color[(cy - 1u) * w + cx];
    let below = input_color[(cy + 1u) * w + cx];
    return c * 0.5 + above * 0.25 + below * 0.25;
}

fn bilinear_sample(x: f32, y: f32, width: u32, height: u32) -> vec4<f32> {
    let ix = u32(floor(x));
    let iy = u32(floor(y));
    let fx = x - floor(x);
    let fy = y - floor(y);

    let x0 = min(ix, width - 1u);
    let x1 = min(ix + 1u, width - 1u);
    let y0 = min(iy, height - 1u);
    let y1 = min(iy + 1u, height - 1u);

    let c00 = fetch_prefiltered(x0, y0, width, height);
    let c10 = fetch_prefiltered(x1, y0, width, height);
    let c01 = fetch_prefiltered(x0, y1, width, height);
    let c11 = fetch_prefiltered(x1, y1, width, height);

    let top = mix(c00, c10, fx);
    let bot = mix(c01, c11, fx);
    return mix(top, bot, fy);
}

fn bilinear_sample_history(uv_x: f32, uv_y: f32) -> vec3<f32> {
    let px = uv_x * f32(params.dst_width) - 0.5;
    let py = uv_y * f32(params.dst_height) - 0.5;
    let ix = u32(floor(max(px, 0.0)));
    let iy = u32(floor(max(py, 0.0)));
    let fx = max(px, 0.0) - floor(max(px, 0.0));
    let fy = max(py, 0.0) - floor(max(py, 0.0));

    let x0 = min(ix, params.dst_width - 1u);
    let x1 = min(ix + 1u, params.dst_width - 1u);
    let y0 = min(iy, params.dst_height - 1u);
    let y1 = min(iy + 1u, params.dst_height - 1u);

    let c00 = history_color[y0 * params.dst_width + x0].rgb;
    let c10 = history_color[y0 * params.dst_width + x1].rgb;
    let c01 = history_color[y1 * params.dst_width + x0].rgb;
    let c11 = history_color[y1 * params.dst_width + x1].rgb;

    let top = mix(c00, c10, fx);
    let bot = mix(c01, c11, fx);
    return mix(top, bot, fy);
}

fn sharpen(idx: u32, width: u32, color: vec3<f32>) -> vec3<f32> {
    let x = idx % width;
    let y = idx / width;

    if (x < 2u || x >= width - 2u || y < 2u) {
        return color;
    }

    let l = input_color[idx - 1u].rgb;
    let r = input_color[idx + 1u].rgb;
    let u = input_color[idx - width].rgb;
    let d = input_color[idx + width].rgb;

    let neighbors_avg = (l + r + u + d) * 0.25;
    let detail = color - neighbors_avg;
    return color + detail * params.sharpness;
}

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= params.dst_width || id.y >= params.dst_height) {
        return;
    }

    let dst_idx = id.y * params.dst_width + id.x;

    if (params.render_scale >= 0.99) {
        if (dst_idx < arrayLength(&input_color)) {
            let color = input_color[dst_idx].rgb;
            let sharpened = sharpen(dst_idx, params.dst_width, color);

            if (params.blend_factor > 0.01 && params.frame_count > 0u) {
                let gbuffer_stride = 8u;
                let depth_raw = gbuffer_depth[dst_idx * gbuffer_stride + 6u];
                let mv = compute_motion_vector(id.x, id.y, depth_raw, params.dst_width, params.dst_height);

                let hist_uv_x = (f32(id.x) + 0.5) / f32(params.dst_width) + mv.x - params.jitter_x + params.prev_jitter_x;
                let hist_uv_y = (f32(id.y) + 0.5) / f32(params.dst_height) + mv.y - params.jitter_y + params.prev_jitter_y;

                if (hist_uv_x >= 0.0 && hist_uv_x < 1.0 && hist_uv_y >= 0.0 && hist_uv_y < 1.0) {
                    let history = bilinear_sample_history(hist_uv_x, hist_uv_y);

                    var nhood_min_ycocg = rgb_to_ycocg(sharpened);
                    var nhood_max_ycocg = nhood_min_ycocg;
                    for (var ny: i32 = -1; ny <= 1; ny++) {
                        for (var nx: i32 = -1; nx <= 1; nx++) {
                            let sx = clamp(i32(id.x) + nx, 0, i32(params.dst_width) - 1);
                            let sy = clamp(i32(id.y) + ny, 0, i32(params.dst_height) - 1);
                            let sidx = u32(sy) * params.dst_width + u32(sx);
                            if (sidx < arrayLength(&input_color)) {
                                let nc = rgb_to_ycocg(input_color[sidx].rgb);
                                nhood_min_ycocg = min(nhood_min_ycocg, nc);
                                nhood_max_ycocg = max(nhood_max_ycocg, nc);
                            }
                        }
                    }

                    let history_ycocg = rgb_to_ycocg(history);
                    let clamped_ycocg = clamp(history_ycocg, nhood_min_ycocg, nhood_max_ycocg);
                    let clamped_history = ycocg_to_rgb(clamped_ycocg);

                    let mv_len = length(mv) * f32(params.dst_width);
                    let velocity_weight = clamp(1.0 - mv_len * 0.1, 0.3, 1.0);
                    let temporal_weight = params.blend_factor * velocity_weight;

                    let final_color = mix(sharpened, clamped_history, min(temporal_weight, 0.9));
                    output_color[dst_idx] = vec4(max(final_color, vec3(0.0)), 1.0);
                } else {
                    output_color[dst_idx] = vec4(max(sharpened, vec3(0.0)), 1.0);
                }
            } else {
                output_color[dst_idx] = vec4(max(sharpened, vec3(0.0)), 1.0);
            }
        }
        return;
    }

    let src_x = (f32(id.x) + 0.5) * f32(params.src_width) / f32(params.dst_width) - 0.5;
    let src_y = (f32(id.y) + 0.5) * f32(params.src_height) / f32(params.dst_height) - 0.5;

    let upscaled = bilinear_sample(
        clamp(src_x, 0.0, f32(params.src_width - 1u)),
        clamp(src_y, 0.0, f32(params.src_height - 1u)),
        params.src_width, params.src_height
    );

    let color = upscaled.rgb;

    let safe_src_x = clamp(src_x, 0.0, f32(params.src_width - 1u));
    let safe_src_y = clamp(src_y, 0.0, f32(params.src_height - 1u));
    let src_idx = min(u32(safe_src_y) * params.src_width + u32(safe_src_x), arrayLength(&input_color) - 1u);

    let gbuffer_stride = 8u;
    let depth_raw = gbuffer_depth[src_idx * gbuffer_stride + 6u];
    let mv = compute_motion_vector(
        u32(safe_src_x), u32(safe_src_y), depth_raw,
        params.src_width, params.src_height
    );

    var nhood_min = color;
    var nhood_max = color;
    let src_ix = u32(floor(safe_src_x));
    let src_iy = u32(floor(safe_src_y));
    for (var ny: i32 = -1; ny <= 1; ny++) {
        for (var nx: i32 = -1; nx <= 1; nx++) {
            let sx = clamp(i32(src_ix) + nx, 0, i32(params.src_width) - 1);
            let sy = clamp(i32(src_iy) + ny, 0, i32(params.src_height) - 1);
            let sidx = u32(sy) * params.src_width + u32(sx);
            if (sidx < arrayLength(&input_color)) {
                let nc = input_color[sidx].rgb;
                nhood_min = min(nhood_min, nc);
                nhood_max = max(nhood_max, nc);
            }
        }
    }

    var final_color = color;

    if (params.blend_factor > 0.01) {
        let hist_uv_x = (f32(id.x) + 0.5) / f32(params.dst_width) + mv.x;
        let hist_uv_y = (f32(id.y) + 0.5) / f32(params.dst_height) + mv.y;

        if (hist_uv_x >= 0.0 && hist_uv_x < 1.0 && hist_uv_y >= 0.0 && hist_uv_y < 1.0) {
            let history = bilinear_sample_history(hist_uv_x, hist_uv_y);
            let clamped_history = clamp(history, nhood_min, nhood_max);
            let mv_len = length(mv) * f32(params.dst_width);
            let velocity_weight = clamp(1.0 - mv_len * 0.1, 0.3, 1.0);
            let temporal_weight = params.blend_factor * velocity_weight;
            final_color = mix(color, clamped_history, min(temporal_weight, 0.7));
        }
    }

    output_color[dst_idx] = vec4(max(final_color, vec3(0.0)), 1.0);
}
