// Screen Space Ambient Occlusion (SSAO) Compute Shader
//
// Estimates ambient occlusion by sampling the depth buffer around each pixel.
// Uses a hemisphere of random sample directions oriented along the surface normal.
// The output is a single f32 per pixel: 1.0 = fully unoccluded, 0.0 = fully occluded.
// Workgroup: 8x8 threads (64 total)

use "wjsl_std/gbuffer.wjsl"

struct SSAOParams {
    radius: f32,
    bias: f32,
    intensity: f32,
    sample_count_packed: u32,
}

@group(0) @binding(0) uniform params: SSAOParams;
@group(0) @binding(1) storage read gbuffer: array<f32>;
@group(0) @binding(2) storage read_write ssao_output: array<f32>;
@group(0) @binding(3) uniform screen_size: vec2<u32>;

fn load_gbuffer_pixel(pixel_idx: u32) -> GBufferPixel {
    let base = gbuffer_base(pixel_idx);
    var g: GBufferPixel;
    g.position = vec4(gbuffer[base], gbuffer[base + 1u], gbuffer[base + 2u], gbuffer[base + 3u]);
    g.normal = vec4(gbuffer[base + 4u], gbuffer[base + 5u], gbuffer[base + 6u], gbuffer[base + 7u]);
    g.depth = gbuffer[base + 8u];
    g.geometry_source = gbuffer[base + 9u];
    return g;
}

fn hash_u32(x: u32) -> f32 {
    var h = x;
    h = h ^ (h >> 16u);
    h = h * 0x45d9f3bu;
    h = h ^ (h >> 16u);
    return f32(h & 0xFFFFu) / 65535.0;
}

fn hash22(p: vec2<f32>) -> vec2<f32> {
    let n = vec2(dot(p, vec2(127.1, 311.7)), dot(p, vec2(269.5, 183.3)));
    return fract(sin(n) * 43758.5453123);
}

fn sample_hemisphere(seed: u32, i: u32) -> vec3<f32> {
    let s = seed * 1013u + i * 7919u;
    let noise = hash22(vec2(f32(s), f32(i)));
    let phi = noise.x * 6.28318530718;
    let cos_theta = noise.y;
    let sin_theta = sqrt(1.0 - cos_theta * cos_theta);
    let r = hash_u32(s + 2u);
    return vec3(sin_theta * cos(phi), sin_theta * sin(phi), cos_theta) * r;
}

fn build_tbn(N: vec3<f32>) -> mat3x3<f32> {
    let is_vertical = abs(N.y) < 0.999;
    let up = select(vec3(1.0, 0.0, 0.0), vec3(0.0, 1.0, 0.0), is_vertical);
    let T = normalize(cross(up, N));
    let B = cross(N, T);
    return mat3x3(T, B, N);
}

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let width = screen_size.x;
    let height = screen_size.y;
    if (id.x >= width || id.y >= height) { return; }

    let pixel_idx = id.y * width + id.x;
    let g = load_gbuffer_pixel(pixel_idx);

    let pos = gbuf_position(g);
    let N = normalize(gbuf_normal(g));
    let depth = g.depth;

    if (depth <= 0.0) {
        ssao_output[pixel_idx] = 1.0;
        return;
    }

    let num_samples = params.sample_count_packed & 0xFFFFu;
    let seed = pixel_idx * 31u + 997u;

    let tbn = build_tbn(N);
    var occlusion = 0.0;
    var valid_samples = 0u;

    for (var i = 0u; i < num_samples; i = i + 1u) {
        let hemisphere_dir = sample_hemisphere(seed, i);
        let scale = 0.1 + 0.9 * f32(i + 1u) / f32(num_samples);
        let offset = tbn * hemisphere_dir * params.radius * scale;

        let sx = clamp(u32(f32(id.x) + offset.x), 0u, width - 1u);
        let sy = clamp(u32(f32(id.y) + offset.y), 0u, height - 1u);
        let sample_idx = sy * width + sx;
        let sample_g = load_gbuffer_pixel(sample_idx);
        let sample_depth = sample_g.depth;

        if (sample_depth > 0.0) {
            let range_check = smoothstep(0.0, 1.0, params.radius / max(abs(depth - sample_depth), 0.001));
            let contribution = select(0.0, 1.0, sample_depth < depth - params.bias);
            occlusion = occlusion + contribution * range_check;
            valid_samples = valid_samples + 1u;
        }
    }

    var ao = 1.0;
    if (valid_samples > 0u) {
        ao = 1.0 - (occlusion / f32(valid_samples)) * params.intensity;
        ao = clamp(ao, 0.0, 1.0);
    }

    ssao_output[pixel_idx] = ao;
}
