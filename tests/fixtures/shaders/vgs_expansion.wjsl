// VGS Expansion Pass - GPU-driven Cluster to Triangle Expansion
//
// Inputs:
// - Cluster buffer (read-only): Geometry data (triangle/vertex offsets)
// - Cluster instances (read-only): Visibility flags from visibility pass
// - Triangle buffer (read-only): Source triangle data
// - Vertex buffer (read-only): Source vertex data
//
// Outputs:
// - Output vertex buffer (read-write): Expanded vertices for rasterization
// - Output index buffer (read-write): Expanded indices for rasterization
// - Draw count (atomic): Total indices written

struct Cluster {
    triangle_count: u32,
    triangle_offset: u32,
    vertex_offset: u32,
    parent_cluster: u32,
    child_clusters: array<u32, 4>,
    lod_level: u32,
    bounds_min: vec3,
    _pad1: u32,
    bounds_max: vec3,
    error_threshold: f32,
    is_leaf: u32,
    _pad2: array<u32, 3>,
}

struct ClusterInstance {
    visible: u32,
    lod_level: u32,
    _pad: vec2<u32>,
}

struct Triangle {
    v0: vec3,
    _pad0: u32,
    v1: vec3,
    _pad1: u32,
    v2: vec3,
    _pad2: u32,
}

struct Vertex {
    position: vec3,
    _pad0: u32,
    normal: vec3,
    _pad1: u32,
    texcoord: vec2,
    _pad2: vec2<u32>,
}

struct ExpansionParams {
    cluster_count: u32,
    max_triangles: u32,
    _pad: vec2<u32>,
}

@group(0) @binding(0) uniform params: ExpansionParams;
@group(0) @binding(1) storage read clusters: array<Cluster>;
@group(0) @binding(2) storage read instances: array<ClusterInstance>;
@group(0) @binding(3) storage read source_triangles: array<Triangle>;
@group(0) @binding(4) storage read_write output_vertices: array<Vertex>;
@group(0) @binding(5) storage read_write output_indices: array<u32>;
@group(0) @binding(6) storage read_write draw_count: atomic<u32>;

@compute @workgroup_size(64, 1, 1)
fn expand_clusters(@builtin(global_invocation_id) id: vec3<u32>) {
    let cluster_id = id.x;

    if (cluster_id >= params.cluster_count) {
        return;
    }

    let instance = instances[cluster_id];

    if (instance.visible == 0u) {
        return;
    }

    let cluster = clusters[cluster_id];

    let indices_needed = cluster.triangle_count * 3u;
    let base_idx = atomicAdd(&draw_count, indices_needed);

    if (base_idx + indices_needed > params.max_triangles * 3u) {
        return;
    }

    for (var tri_idx = 0u; tri_idx < cluster.triangle_count; tri_idx++) {
        let source_tri_idx = cluster.triangle_offset + tri_idx;
        let triangle = source_triangles[source_tri_idx];

        let out_idx = base_idx + tri_idx * 3u;
        let vertex_base = base_idx + tri_idx * 3u;

        output_indices[out_idx + 0u] = vertex_base + 0u;
        output_indices[out_idx + 1u] = vertex_base + 1u;
        output_indices[out_idx + 2u] = vertex_base + 2u;

        output_vertices[vertex_base + 0u].position = triangle.v0;
        output_vertices[vertex_base + 1u].position = triangle.v1;
        output_vertices[vertex_base + 2u].position = triangle.v2;

        let edge1 = triangle.v1 - triangle.v0;
        let edge2 = triangle.v2 - triangle.v0;
        let normal = normalize(cross(edge1, edge2));

        output_vertices[vertex_base + 0u].normal = normal;
        output_vertices[vertex_base + 1u].normal = normal;
        output_vertices[vertex_base + 2u].normal = normal;

        output_vertices[vertex_base + 0u].texcoord = vec2(0.0, 0.0);
        output_vertices[vertex_base + 1u].texcoord = vec2(1.0, 0.0);
        output_vertices[vertex_base + 2u].texcoord = vec2(0.5, 1.0);
    }
}

@compute @workgroup_size(64, 1, 1)
fn expand_clusters_indirect(@builtin(global_invocation_id) id: vec3<u32>) {
    let cluster_id = id.x;

    if (cluster_id >= params.cluster_count) {
        return;
    }

    let instance = instances[cluster_id];

    if (instance.visible == 0u) {
        return;
    }

    let cluster = clusters[cluster_id];

    let visible_idx = atomicAdd(&draw_count, 1u);
}
