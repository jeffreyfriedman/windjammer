// WJSL Standard Library: Virtualized Geometry System Types
//
// Shared cluster and instance types for visibility culling and expansion passes.

struct Cluster {
    center: vec3<f32>,
    radius: f32,
    lod_level: u32,
    triangle_offset: u32,
    triangle_count: u32,
    _pad: u32,
}

struct ClusterInstance {
    cluster_id: u32,
    lod_level: u32,
    screen_size: f32,
    _pad: u32,
}

struct Triangle {
    v0: vec3<f32>,
    _pad0: f32,
    v1: vec3<f32>,
    _pad1: f32,
    v2: vec3<f32>,
    _pad2: f32,
}

struct Vertex {
    position: vec3<f32>,
    _pad: f32,
}
