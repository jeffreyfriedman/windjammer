// HUD Overlay Compute Shader (WJSL)
//
// Renders game HUD elements directly into the LDR framebuffer:
// - Center crosshair with hit marker feedback
// - Health bar (bottom-left, red/green gradient)
// - Energy bar (below health)
// - Ammo counter (bottom-right, segmented display)
// - XP bar (bottom-center, subtle progression indicator)
// - Level / skill points display (top-left cluster)
// - Damage indicator (screen-edge red flash)
// - Inventory count (bottom-right below ammo)
//
// Workgroup: 8x8 threads (64 total)

struct HudParams {
    health: f32,
    max_health: f32,
    ammo: f32,
    max_ammo: f32,
    damage_flash: f32,
    crosshair_size: f32,
    energy: f32,
    max_energy: f32,
    fps: f32,
    kill_count: f32,
    debug_enabled: f32,
    crosshair_material_id: f32,
    camera_x: f32,
    camera_y: f32,
    camera_z: f32,
    nearest_enemy_dist: f32,
    collision_blocked: f32,
    camera_yaw: f32,
    camera_pitch: f32,
    crosshair_hit: f32,
    level: f32,
    xp_current: f32,
    xp_to_next: f32,
    skill_points: f32,
    inventory_count: f32,
    inventory_capacity: f32,
    weapon_form: f32,
    wave_number: f32,
    quest_id: f32,
    quest_progress: f32,
    quest_target: f32,
    death_timer: f32,
    damage_indicator_angle: f32,
    damage_indicator_alpha: f32,
    paused: f32,
    menu_selection: f32,
    settings_open: f32,
    quality_tier: f32,
    onboarding_timer: f32,
    dialog_active: f32,
    dialog_speaker_id: f32,
    dialog_choice_count: f32,
    dialog_selected_choice: f32,
    npc_prompt_active: f32,
    npc_prompt_id: f32,
    notify_type: f32,
    notify_timer: f32,
    target_health: f32,
    target_max_health: f32,
    target_alert: f32,
    target_visible: f32,
    metrics_overlay: f32,
    metrics_frame_ms: f32,
    metrics_mem_mb: f32,
    metrics_draw_calls: f32,
    metrics_mem_budget: f32,
    metrics_draw_budget: f32,
    metrics_drill: f32,
    metrics_game_ms: f32,
    metrics_render_ms: f32,
    skill_tree_open: f32,
    inventory_open: f32,
    ability_unlock_mask: f32,
}

@group(0) @binding(0) uniform hud: HudParams;
@group(0) @binding(1) storage read_write framebuffer: array<vec4<f32> >;
@group(0) @binding(2) uniform screen_size: vec2<u32 >;
@group(0) @binding(3) storage read minimap_data: array<f32>;

fn draw_crosshair(px: u32, py: u32, cx: u32, cy: u32, size: f32, hit: f32) -> vec4<f32> {
    let dx = abs(f32(px) - f32(cx));
    let dy = abs(f32(py) - f32(cy));

    // Center dot (3x3)
    if (dx <= 1.5 && dy <= 1.5) {
        if (hit > 0.0) {
            return vec4(1.0, 0.3, 0.1, 1.0);
        }
        return vec4(1.0, 1.0, 1.0, 1.0);
    }

    // Hit marker: diagonal lines when crosshair_hit > 0
    if (hit > 0.0) {
        let diag_dist = abs(dx - dy);
        if (diag_dist <= 1.2 && dx >= 4.0 && dx <= size * 0.8 && dy >= 4.0 && dy <= size * 0.8) {
            return vec4(1.0, 0.2, 0.05, hit);
        }
    }

    // Dark outline for visibility against bright backgrounds
    if (dy <= 2.0 && dx >= 3.0 && dx <= size + 1.5) {
        return vec4(0.0, 0.0, 0.0, 0.5);
    }
    if (dx <= 2.0 && dy >= 3.0 && dy <= size + 1.5) {
        return vec4(0.0, 0.0, 0.0, 0.5);
    }

    // Horizontal line
    if (dy <= 0.8 && dx >= 4.0 && dx <= size) {
        return vec4(0.9, 0.95, 0.9, 0.95);
    }

    // Vertical line
    if (dx <= 0.8 && dy >= 4.0 && dy <= size) {
        return vec4(0.9, 0.95, 0.9, 0.95);
    }

    return vec4(0.0, 0.0, 0.0, 0.0);
}

fn draw_health_bar(px: u32, py: u32, width: u32, height: u32, health_pct: f32) -> vec4<f32> {
    let bar_w = 300u;
    let bar_h = 20u;
    let bar_x = 20u;
    let bar_y = height - 70u;

    if (px >= bar_x && px < bar_x + bar_w && py >= bar_y && py < bar_y + bar_h) {
        let local_x = f32(px - bar_x) / f32(bar_w);

        if (px == bar_x || px == bar_x + bar_w - 1u || py == bar_y || py == bar_y + bar_h - 1u) {
            return vec4(0.7, 0.7, 0.7, 0.85);
        }

        if (local_x <= health_pct) {
            let r = 1.0 - health_pct;
            let g = health_pct;
            return vec4(r, g, 0.1, 0.85);
        }

        return vec4(0.1, 0.1, 0.1, 0.6);
    }
    return vec4(0.0, 0.0, 0.0, 0.0);
}

fn draw_energy_bar(px: u32, py: u32, width: u32, height: u32, energy_pct: f32) -> vec4<f32> {
    let bar_w = 300u;
    let bar_h = 14u;
    let bar_x = 20u;
    let bar_y = height - 46u;

    if (px >= bar_x && px < bar_x + bar_w && py >= bar_y && py < bar_y + bar_h) {
        let local_x = f32(px - bar_x) / f32(bar_w);

        if (px == bar_x || px == bar_x + bar_w - 1u || py == bar_y || py == bar_y + bar_h - 1u) {
            return vec4(0.5, 0.6, 0.8, 0.75);
        }

        if (local_x <= energy_pct) {
            return vec4(0.15, 0.55, 1.0, 0.80);
        }

        return vec4(0.08, 0.08, 0.12, 0.5);
    }
    return vec4(0.0, 0.0, 0.0, 0.0);
}

fn draw_ammo_bar(px: u32, py: u32, width: u32, height: u32, ammo_pct: f32) -> vec4<f32> {
    let bar_w = 180u;
    let bar_h = 18u;
    let bar_x = width - 200u;
    let bar_y = height - 70u;

    if (px >= bar_x && px < bar_x + bar_w && py >= bar_y && py < bar_y + bar_h) {
        let local_x = f32(px - bar_x) / f32(bar_w);

        if (px == bar_x || px == bar_x + bar_w - 1u || py == bar_y || py == bar_y + bar_h - 1u) {
            return vec4(0.6, 0.7, 0.8, 0.9);
        }

        let segment = f32(bar_w) / 10.0;
        let seg_frac = fract(f32(px - bar_x) / segment);

        if (seg_frac > 0.85) {
            return vec4(0.1, 0.1, 0.1, 0.6);
        }

        if (local_x <= ammo_pct) {
            return vec4(0.3, 0.7, 1.0, 0.85);
        }

        return vec4(0.1, 0.1, 0.15, 0.6);
    }
    return vec4(0.0, 0.0, 0.0, 0.0);
}

fn draw_xp_bar(px: u32, py: u32, width: u32, height: u32, xp_pct: f32) -> vec4<f32> {
    let bar_w = 400u;
    let bar_h = 10u;
    let bar_x = (width - bar_w) / 2u;
    let bar_y = height - 24u;

    if (px >= bar_x && px < bar_x + bar_w && py >= bar_y && py < bar_y + bar_h) {
        let local_x = f32(px - bar_x) / f32(bar_w);

        if (py == bar_y || py == bar_y + bar_h - 1u) {
            return vec4(0.4, 0.35, 0.6, 0.5);
        }

        if (local_x <= xp_pct) {
            return vec4(0.6, 0.4, 1.0, 0.75);
        }

        return vec4(0.08, 0.06, 0.12, 0.4);
    }
    return vec4(0.0, 0.0, 0.0, 0.0);
}

fn draw_damage_flash(px: u32, py: u32, width: u32, height: u32, intensity: f32) -> vec4<f32> {
    if (intensity <= 0.01) { return vec4(0.0); }

    let uv = vec2(f32(px) / f32(width), f32(py) / f32(height));
    let edge_dist = min(min(uv.x, 1.0 - uv.x), min(uv.y, 1.0 - uv.y));
    let edge_factor = smoothstep(0.08, 0.0, edge_dist);
    return vec4(0.9, 0.05, 0.02, edge_factor * intensity * 0.35);
}

fn draw_damage_direction(px: u32, py: u32, width: u32, height: u32, angle: f32, alpha: f32) -> vec4<f32> {
    if (alpha <= 0.01) { return vec4(0.0); }

    let cx = f32(width) * 0.5;
    let cy = f32(height) * 0.5;
    let dx = f32(px) - cx;
    let dy = f32(py) - cy;
    let pixel_dist = sqrt(dx * dx + dy * dy);
    let screen_r = min(cx, cy);

    if (pixel_dist < screen_r * 0.35 || pixel_dist > screen_r * 0.95) {
        return vec4(0.0);
    }

    let pixel_angle = atan2(dy, dx);
    var angle_diff = pixel_angle - angle;
    angle_diff = angle_diff - round(angle_diff / 6.28318) * 6.28318;

    let arc_width = 0.5;
    let arc_factor = 1.0 - smoothstep(0.0, arc_width, abs(angle_diff));
    if (arc_factor <= 0.0) { return vec4(0.0); }

    let edge = smoothstep(screen_r * 0.35, screen_r * 0.45, pixel_dist) *
               (1.0 - smoothstep(screen_r * 0.85, screen_r * 0.95, pixel_dist));
    let a = arc_factor * edge * alpha * 0.6;
    return vec4(1.0, 0.1, 0.05, a);
}

fn draw_weapon_indicator(px: u32, py: u32, width: u32, height: u32, form: f32) -> vec4<f32> {
    let ind_w = 120u;
    let ind_h = 32u;
    let ind_x = (width - ind_w) / 2u;
    let ind_y = height - 50u;

    if (px < ind_x || px >= ind_x + ind_w || py < ind_y || py >= ind_y + ind_h) {
        return vec4(0.0);
    }

    let bg = vec4(0.0, 0.0, 0.05, 0.55);
    let scale = 3u;
    let cw = 6u * scale;
    let ty = ind_y + 5u;
    let tx = ind_x + 10u;

    let form_i = i32(form + 0.5);

    if (form_i == 0) {
        // RPD (Rapid Fire)
        let c = vec4(0.3, 1.0, 0.4, 1.0);
        if (draw_letter_s(px, py, tx, ty, 17, scale)) { return c; }           // R
        if (draw_letter_s(px, py, tx + cw, ty, 15, scale)) { return c; }      // P
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 3, scale)) { return c; }  // D
    } else if (form_i == 1) {
        // CHG (Charge)
        let c = vec4(1.0, 0.8, 0.1, 1.0);
        if (draw_letter_s(px, py, tx, ty, 2, scale)) { return c; }            // C
        if (draw_letter_s(px, py, tx + cw, ty, 7, scale)) { return c; }       // H
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 6, scale)) { return c; }  // G
    } else if (form_i == 2) {
        // SCT (Scatter)
        let c = vec4(1.0, 0.4, 0.2, 1.0);
        if (draw_letter_s(px, py, tx, ty, 18, scale)) { return c; }           // S
        if (draw_letter_s(px, py, tx + cw, ty, 2, scale)) { return c; }       // C
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 19, scale)) { return c; } // T
    } else {
        // PRC (Pierce)
        let c = vec4(0.4, 0.6, 1.0, 1.0);
        if (draw_letter_s(px, py, tx, ty, 15, scale)) { return c; }           // P
        if (draw_letter_s(px, py, tx + cw, ty, 17, scale)) { return c; }      // R
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 2, scale)) { return c; }  // C
    }

    return bg;
}

fn draw_wave_indicator(px: u32, py: u32, width: u32) -> vec4<f32> {
    let ind_w = 130u;
    let ind_h = 32u;
    let ind_x = width - ind_w - 16u;
    let ind_y = 16u;

    if (px < ind_x || px >= ind_x + ind_w || py < ind_y || py >= ind_y + ind_h) {
        return vec4(0.0);
    }

    let bg = vec4(0.0, 0.0, 0.0, 0.55);
    let scale = 3u;
    let cw = 6u * scale;
    let ty = ind_y + 5u;
    let tx = ind_x + 8u;

    // "H" (wave) + number
    let label_color = vec4(0.9, 0.6, 0.1, 1.0);
    let num_color = vec4(1.0, 0.9, 0.3, 1.0);

    if (draw_letter_s(px, py, tx, ty, 7, scale)) { return label_color; } // H (for "Horde")
    if (draw_number_s(px, py, tx + cw + 4u, ty, hud.wave_number, 2, 0, scale)) { return num_color; }

    return bg;
}

// 7-segment digit renderer (5x7 pixel glyphs)
const SEGMENT_MASKS: array<u32, 11> = array<u32, 11>(
    0x3Fu, 0x06u, 0x5Bu, 0x4Fu, 0x66u,
    0x6Du, 0x7Du, 0x07u, 0x7Fu, 0x6Fu,
    0x40u
);

fn segment_mask(digit: i32) -> u32 {
    if (digit < 0 || digit > 10) { return 0x40u; }
    return SEGMENT_MASKS[digit];
}

fn draw_digit(px: u32, py: u32, ox: u32, oy: u32, digit: i32) -> bool {
    let lx = i32(px) - i32(ox);
    let ly = i32(py) - i32(oy);
    if (lx < 0 || lx > 4 || ly < 0 || ly > 6) { return false; }

    let mask = segment_mask(digit);

    if (ly == 0 && lx >= 1 && lx <= 3 && (mask & 1u) != 0u) { return true; }
    if (lx == 4 && ly >= 1 && ly <= 2 && (mask & 2u) != 0u) { return true; }
    if (lx == 4 && ly >= 4 && ly <= 5 && (mask & 4u) != 0u) { return true; }
    if (ly == 6 && lx >= 1 && lx <= 3 && (mask & 8u) != 0u) { return true; }
    if (lx == 0 && ly >= 4 && ly <= 5 && (mask & 16u) != 0u) { return true; }
    if (lx == 0 && ly >= 1 && ly <= 2 && (mask & 32u) != 0u) { return true; }
    if (ly == 3 && lx >= 1 && lx <= 3 && (mask & 64u) != 0u) { return true; }

    return false;
}

fn draw_number(px: u32, py: u32, ox: u32, oy: u32, value: f32, digits: i32, decimals: i32) -> bool {
    let mut v = value;
    let is_neg = v < 0.0;
    if (is_neg) { v = -v; }

    for (var d = 0; d < decimals; d = d + 1) {
        v = v * 10.0;
    }
    let mut int_val = i32(v + 0.5);

    let total_chars = digits + select(0, 1, decimals > 0) + select(0, 1, is_neg);
    let char_width = 6u;

    for (var ci = total_chars - 1; ci >= 0; ci = ci - 1) {
        let char_x = ox + u32(ci) * char_width;

        let from_right = total_chars - 1 - ci;
        if (decimals > 0 && from_right == decimals) {
            if (px == char_x + 2u && py == oy) { return true; }
            continue;
        }

        if (is_neg && ci == 0) {
            if (draw_digit(px, py, char_x, oy, 10)) { return true; }
            continue;
        }

        let d = int_val % 10;
        int_val = int_val / 10;
        if (draw_digit(px, py, char_x, oy, d)) { return true; }
    }
    return false;
}

fn draw_level_indicator(px: u32, py: u32, width: u32) -> vec4<f32> {
    let panel_x = 20u;
    let panel_y = 20u;
    let scale = 3u;
    let cw = 6u * scale;
    let panel_w = 160u;
    let panel_h = 70u;

    if (px < panel_x || px >= panel_x + panel_w || py < panel_y || py >= panel_y + panel_h) {
        return vec4(0.0);
    }

    let mut result = vec4(0.0, 0.0, 0.05, 0.55);

    let level_color = vec4(0.2, 0.85, 1.0, 1.0);
    if (draw_letter_s(px, py, panel_x + 8u, panel_y + 6u, 11, scale)) { return level_color; } // L
    if (draw_number_s(px, py, panel_x + 8u + cw, panel_y + 6u, hud.level, 2, 0, scale)) {
        return level_color;
    }

    if (hud.skill_points > 0.0) {
        let sp_color = vec4(1.0, 0.85, 0.2, 1.0);
        if (draw_number_s(px, py, panel_x + 8u + cw * 4u, panel_y + 6u, hud.skill_points, 2, 0, scale)) {
            return sp_color;
        }
    }

    let kill_color = vec4(1.0, 0.3, 0.2, 0.9);
    if (draw_number_s(px, py, panel_x + 8u, panel_y + 36u, hud.kill_count, 3, 0, scale)) {
        return kill_color;
    }

    let fps_color = vec4(0.5, 0.8, 0.5, 0.7);
    if (draw_number_s(px, py, panel_x + 8u + cw * 4u, panel_y + 36u, hud.fps, 3, 0, scale)) {
        return fps_color;
    }

    return result;
}

fn draw_inventory_indicator(px: u32, py: u32, width: u32, height: u32) -> vec4<f32> {
    let ind_x = width - 140u;
    let ind_y = height - 42u;
    let ind_w = 60u;
    let ind_h = 12u;

    if (px < ind_x || px >= ind_x + ind_w || py < ind_y || py >= ind_y + ind_h) {
        return vec4(0.0);
    }

    let inv_color = vec4(0.7, 0.75, 0.55, 0.85);
    if (draw_number(px, py, ind_x + 4u, ind_y + 3u, hud.inventory_count, 2, 0)) {
        return inv_color;
    }
    if (draw_number(px, py, ind_x + 22u, ind_y + 3u, hud.inventory_capacity, 2, 0)) {
        return inv_color;
    }

    return vec4(0.0, 0.0, 0.0, 0.35);
}

fn draw_dialog_portrait(px: u32, py: u32, dbox_x: u32, dbox_y: u32, dbox_h: u32) -> vec4<f32> {
    let sid = u32(hud.dialog_speaker_id + 0.5);
    if (sid == 0u) { return vec4(0.0); }

    let port_x = dbox_x + 8u;
    let port_y = dbox_y + 28u;
    let port_w = 72u;
    let port_h = dbox_h - 36u;
    if (px < port_x || px >= port_x + port_w || py < port_y || py >= port_y + port_h) {
        return vec4(0.0);
    }

    var tint = vec3(0.35, 0.55, 0.85);
    if (sid == 2u) { tint = vec3(0.35, 0.75, 0.45); }
    if (sid == 3u) { tint = vec3(0.85, 0.65, 0.25); }

    let rx = px - port_x;
    let ry = py - port_y;
    if (rx < 2u || rx >= port_w - 2u || ry < 2u || ry >= port_h - 2u) {
        return vec4(tint * 1.3, 0.95);
    }
    // Simple face oval
    let cx = f32(port_w) * 0.5;
    let cy = f32(port_h) * 0.42;
    let dx = f32(rx) - cx;
    let dy = f32(ry) - cy;
    if (dx * dx / (cx * cx) + dy * dy / (cy * cy) < 1.0) {
        return vec4(tint, 0.92);
    }
    return vec4(tint * 0.35, 0.85);
}

fn draw_digit_s(px: u32, py: u32, ox: u32, oy: u32, digit: i32, scale: u32) -> bool {
    let lx = i32(px) - i32(ox);
    let ly = i32(py) - i32(oy);
    let w = i32(5 * scale);
    let h = i32(7 * scale);
    if (lx < 0 || lx >= w || ly < 0 || ly >= h) { return false; }
    let gx = u32(lx) / scale;
    let gy = u32(ly) / scale;
    let mask = segment_mask(digit);
    if (gy == 0u && gx >= 1u && gx <= 3u && (mask & 1u) != 0u) { return true; }
    if (gx == 4u && gy >= 1u && gy <= 2u && (mask & 2u) != 0u) { return true; }
    if (gx == 4u && gy >= 4u && gy <= 5u && (mask & 4u) != 0u) { return true; }
    if (gy == 6u && gx >= 1u && gx <= 3u && (mask & 8u) != 0u) { return true; }
    if (gx == 0u && gy >= 4u && gy <= 5u && (mask & 16u) != 0u) { return true; }
    if (gx == 0u && gy >= 1u && gy <= 2u && (mask & 32u) != 0u) { return true; }
    if (gy == 3u && gx >= 1u && gx <= 3u && (mask & 64u) != 0u) { return true; }
    return false;
}

fn draw_number_s(px: u32, py: u32, ox: u32, oy: u32, value: f32, digits: i32, decimals: i32, scale: u32) -> bool {
    let mut v = value;
    let is_neg = v < 0.0;
    if (is_neg) { v = -v; }
    for (var d = 0; d < decimals; d = d + 1) { v = v * 10.0; }
    let mut int_val = i32(v + 0.5);
    let total_chars = digits + select(0, 1, decimals > 0) + select(0, 1, is_neg);
    let char_width = 6u * scale;
    for (var ci = total_chars - 1; ci >= 0; ci = ci - 1) {
        let char_x = ox + u32(ci) * char_width;
        let from_right = total_chars - 1 - ci;
        if (decimals > 0 && from_right == decimals) {
            let dot_x = char_x + 2u * scale;
            let dot_y = oy;
            if (px >= dot_x && px < dot_x + scale && py >= dot_y && py < dot_y + scale) { return true; }
            continue;
        }
        if (is_neg && ci == 0) {
            if (draw_digit_s(px, py, char_x, oy, 10, scale)) { return true; }
            continue;
        }
        let d = int_val % 10;
        int_val = int_val / 10;
        if (draw_digit_s(px, py, char_x, oy, d, scale)) { return true; }
    }
    return false;
}

// 7-segment letter masks as array lookup (avoids 30+ branch if-else chain
// that caused Metal shader compiler to hang during pipeline creation)
const LETTER_MASKS: array<u32, 44> = array<u32, 44>(
    0x77u, // 0  A
    0x7Cu, // 1  B
    0x39u, // 2  C
    0x5Eu, // 3  D
    0x79u, // 4  E
    0x71u, // 5  F
    0x3Du, // 6  G
    0x76u, // 7  H
    0x06u, // 8  I
    0x1Eu, // 9  J
    0x76u, // 10 K
    0x38u, // 11 L
    0x37u, // 12 M
    0x37u, // 13 N
    0x3Fu, // 14 O
    0x73u, // 15 P
    0x67u, // 16 Q
    0x50u, // 17 R
    0x6Du, // 18 S
    0x78u, // 19 T
    0x3Eu, // 20 U
    0x3Eu, // 21 V
    0x3Eu, // 22 W
    0x76u, // 23 X
    0x6Eu, // 24 Y
    0x5Bu, // 25 Z
    0x00u, // 26-35 digits handled by draw_digit_s (placeholder)
    0x00u, 0x00u, 0x00u, 0x00u,
    0x00u, 0x00u, 0x00u, 0x00u, 0x00u,
    0x00u, // 36 space
    0x08u, // 37 period
    0x10u, // 38 comma
    0x40u, // 39 dash
    0x48u, // 40 colon
    0x06u, // 41 exclamation
    0x53u, // 42 question mark
    0x02u  // 43 apostrophe
);

fn letter_mask(ch: i32) -> u32 {
    if (ch < 0 || ch > 43) { return 0x00u; }
    return LETTER_MASKS[ch];
}

fn char_to_code(ascii: u32) -> i32 {
    if (ascii >= 65u && ascii <= 90u) { return i32(ascii - 65u); }
    if (ascii >= 97u && ascii <= 122u) { return i32(ascii - 97u); }
    if (ascii >= 48u && ascii <= 57u) { return i32(ascii - 48u + 26u); }
    if (ascii == 32u) { return i32(36); }
    if (ascii == 46u) { return i32(37); }
    if (ascii == 44u) { return i32(38); }
    if (ascii == 45u) { return i32(39); }
    if (ascii == 58u) { return i32(40); }
    if (ascii == 33u) { return i32(41); }
    if (ascii == 63u) { return i32(42); }
    if (ascii == 39u) { return i32(43); }
    return i32(36);
}

fn draw_char_s(px: u32, py: u32, ox: u32, oy: u32, ch: i32, scale: u32) -> bool {
    if (ch >= 26 && ch <= 35) {
        return draw_digit_s(px, py, ox, oy, ch - 26, scale);
    }
    return draw_letter_s(px, py, ox, oy, ch, scale);
}

fn draw_letter_s(px: u32, py: u32, ox: u32, oy: u32, ch: i32, scale: u32) -> bool {
    var code = ch;
    // Accept ASCII (panels/menus pass 'A'=65) or HUD glyph index (0-43).
    if (code > 43) {
        code = char_to_code(u32(code));
    }
    let lx = i32(px) - i32(ox);
    let ly = i32(py) - i32(oy);
    let w = i32(5 * scale);
    let h = i32(7 * scale);
    if (lx < 0 || lx >= w || ly < 0 || ly >= h) { return false; }
    let gx = u32(lx) / scale;
    let gy = u32(ly) / scale;
    let mask = letter_mask(code);
    if (gy == 0u && gx >= 1u && gx <= 3u && (mask & 1u) != 0u) { return true; }
    if (gx == 4u && gy >= 1u && gy <= 2u && (mask & 2u) != 0u) { return true; }
    if (gx == 4u && gy >= 4u && gy <= 5u && (mask & 4u) != 0u) { return true; }
    if (gy == 6u && gx >= 1u && gx <= 3u && (mask & 8u) != 0u) { return true; }
    if (gx == 0u && gy >= 4u && gy <= 5u && (mask & 16u) != 0u) { return true; }
    if (gx == 0u && gy >= 1u && gy <= 2u && (mask & 32u) != 0u) { return true; }
    if (gy == 3u && gx >= 1u && gx <= 3u && (mask & 64u) != 0u) { return true; }
    return false;
}

fn metrics_budget_color(ratio: f32) -> vec4<f32> {
    if (ratio > 1.0) {
        return vec4(0.91, 0.30, 0.24, 1.0);
    }
    if (ratio > 0.85) {
        return vec4(0.95, 0.61, 0.07, 1.0);
    }
    return vec4(0.18, 0.80, 0.44, 1.0);
}

fn draw_metrics_panel(px: u32, py: u32, width: u32) -> vec4<f32> {
    if (hud.metrics_overlay < 0.5) { return vec4(0.0); }

    let scale = 2u;
    let cw = 6u * scale;
    let rh = 8u * scale;
    let panel_w = 280u;
    let panel_h = if (hud.metrics_drill > 0.5) { rh * 7u + 16u } else { rh * 5u + 16u };
    let panel_x = width - panel_w - 12u;
    let panel_y = 12u;

    if (px < panel_x || px >= panel_x + panel_w || py < panel_y || py >= panel_y + panel_h) {
        return vec4(0.0);
    }

    let mut result = vec4(0.0, 0.0, 0.0, 0.65);
    let label_color = vec4(0.55, 0.75, 0.95, 1.0);
    let lx = panel_x + 6u;
    let vx = panel_x + 6u + cw * 4u;
    let frame_budget = 1000.0 / 60.0;
    let frame_ratio = hud.metrics_frame_ms / frame_budget;
    let mem_ratio = if (hud.metrics_mem_budget > 0.0) {
        hud.metrics_mem_mb / hud.metrics_mem_budget
    } else {
        0.0
    };
    let draw_ratio = if (hud.metrics_draw_budget > 0.0) {
        hud.metrics_draw_calls / hud.metrics_draw_budget
    } else {
        0.0
    };

    var row = panel_y + 6u;

    if (draw_letter_s(px, py, lx, row, 5, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw, row, 15, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw * 2u, row, 18, scale)) { return label_color; }
    if (draw_number_s(px, py, vx, row, hud.fps, 4, 0, scale)) {
        return metrics_budget_color(if (hud.fps >= 60.0) { 0.5 } else { 1.1 });
    }

    row = row + rh;
    if (draw_letter_s(px, py, lx, row, 5, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw, row, 17, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw * 2u, row, 0, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw * 3u, row, 12, scale)) { return label_color; }
    if (draw_number_s(px, py, vx, row, hud.metrics_frame_ms, 4, 1, scale)) {
        return metrics_budget_color(frame_ratio);
    }

    row = row + rh;
    if (draw_letter_s(px, py, lx, row, 12, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw, row, 4, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw * 2u, row, 12, scale)) { return label_color; }
    if (draw_number_s(px, py, vx, row, hud.metrics_mem_mb, 4, 0, scale)) {
        return metrics_budget_color(mem_ratio);
    }

    row = row + rh;
    if (draw_letter_s(px, py, lx, row, 3, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw, row, 17, scale)) { return label_color; }
    if (draw_letter_s(px, py, lx + cw * 2u, row, 22, scale)) { return label_color; }
    if (draw_number_s(px, py, vx, row, hud.metrics_draw_calls, 4, 0, scale)) {
        return metrics_budget_color(draw_ratio);
    }

    if (hud.metrics_drill > 0.5) {
        row = row + rh;
        if (draw_letter_s(px, py, lx, row, 6, scale)) { return label_color; }
        if (draw_letter_s(px, py, lx + cw, row, 0, scale)) { return label_color; }
        if (draw_letter_s(px, py, lx + cw * 2u, row, 12, scale)) { return label_color; }
        if (draw_letter_s(px, py, lx + cw * 3u, row, 4, scale)) { return label_color; }
        if (draw_number_s(px, py, vx, row, hud.metrics_game_ms, 3, 1, scale)) {
            return vec4(0.7, 0.9, 1.0, 1.0);
        }

        row = row + rh;
        if (draw_letter_s(px, py, lx, row, 17, scale)) { return label_color; }
        if (draw_letter_s(px, py, lx + cw, row, 4, scale)) { return label_color; }
        if (draw_letter_s(px, py, lx + cw * 2u, row, 12, scale)) { return label_color; }
        if (draw_number_s(px, py, vx, row, hud.metrics_render_ms, 3, 1, scale)) {
            return vec4(0.7, 0.9, 1.0, 1.0);
        }
    }

    return result;
}

fn draw_debug_panel(px: u32, py: u32, width: u32) -> vec4<f32> {
    if (hud.debug_enabled < 0.5) { return vec4(0.0); }

    let scale = 3u;
    let cw = 6u * scale;
    let rh = 8u * scale;
    let panel_x = 12u;
    let panel_y = 100u;
    let panel_w = 420u;
    let panel_h = rh * 5u + 16u;

    if (px < panel_x || px >= panel_x + panel_w || py < panel_y || py >= panel_y + panel_h) {
        return vec4(0.0);
    }

    let mut result = vec4(0.0, 0.0, 0.0, 0.6);
    let label_color = vec4(0.5, 0.7, 0.9, 1.0);
    let value_color = vec4(0.0, 1.0, 0.4, 1.0);
    let lx = panel_x + 6u;
    let vx = panel_x + 6u + cw * 5u;

    // Rows laid out bottom-to-top (y=0 is screen bottom)
    // Row 5 (bottom): FPS
    let r5 = panel_y + 6u;
    if (draw_letter_s(px, py, lx, r5, 5, scale)) { return label_color; }             // F
    if (draw_letter_s(px, py, lx + cw, r5, 15, scale)) { return label_color; }       // P
    if (draw_letter_s(px, py, lx + cw * 2u, r5, 18, scale)) { return label_color; }  // S
    if (draw_number_s(px, py, vx, r5, hud.fps, 4, 0, scale)) { return value_color; }

    // Row 4: COL  collision status + material ID
    let r4 = r5 + rh;
    if (draw_letter_s(px, py, lx, r4, 2, scale)) { return label_color; }             // C
    if (draw_letter_s(px, py, lx + cw, r4, 14, scale)) { return label_color; }       // O
    if (draw_letter_s(px, py, lx + cw * 2u, r4, 11, scale)) { return label_color; }  // L
    if (hud.collision_blocked > 0.5) {
        let bx = vx;
        if (px >= bx && px < bx + 3u * scale && py >= r4 && py < r4 + 7u * scale) {
            return vec4(1.0, 0.2, 0.1, 1.0);
        }
    } else {
        let bx = vx;
        if (px >= bx && px < bx + 3u * scale && py >= r4 && py < r4 + 7u * scale) {
            return vec4(0.1, 0.8, 0.3, 1.0);
        }
    }
    if (draw_number_s(px, py, vx + cw * 3u, r4, hud.crosshair_material_id, 3, 0, scale)) { return value_color; }

    // Row 3: dSt  nearest enemy distance
    let r3 = r4 + rh;
    if (draw_letter_s(px, py, lx, r3, 3, scale)) { return label_color; }             // d
    if (draw_letter_s(px, py, lx + cw, r3, 18, scale)) { return label_color; }       // S
    if (draw_letter_s(px, py, lx + cw * 2u, r3, 19, scale)) { return label_color; }  // t
    if (draw_number_s(px, py, vx, r3, hud.nearest_enemy_dist, 5, 1, scale)) { return value_color; }

    // Row 2: ANE  yaw pitch (degrees)
    let r2 = r3 + rh;
    if (draw_letter_s(px, py, lx, r2, 0, scale)) { return label_color; }             // A
    if (draw_letter_s(px, py, lx + cw, r2, 13, scale)) { return label_color; }       // N
    if (draw_letter_s(px, py, lx + cw * 2u, r2, 4, scale)) { return label_color; }   // E (anglE)
    if (draw_number_s(px, py, vx, r2, hud.camera_yaw * 57.2958, 4, 0, scale)) { return value_color; }
    if (draw_number_s(px, py, vx + cw * 5u, r2, hud.camera_pitch * 57.2958, 4, 0, scale)) { return value_color; }

    // Row 1 (top): POS  X Y Z
    let r1 = r2 + rh;
    if (draw_letter_s(px, py, lx, r1, 15, scale)) { return label_color; }           // P
    if (draw_letter_s(px, py, lx + cw, r1, 14, scale)) { return label_color; }      // O
    if (draw_letter_s(px, py, lx + cw * 2u, r1, 18, scale)) { return label_color; } // S
    if (draw_number_s(px, py, vx, r1, hud.camera_x, 4, 0, scale)) { return value_color; }
    if (draw_number_s(px, py, vx + cw * 5u, r1, hud.camera_y, 4, 0, scale)) { return value_color; }
    if (draw_number_s(px, py, vx + cw * 10u, r1, hud.camera_z, 4, 0, scale)) { return value_color; }

    return result;
}

fn draw_onboarding_overlay(px: u32, py: u32, width: u32, height: u32) -> vec4<f32> {
    let timer = hud.onboarding_timer;
    if (timer <= 0.0) { return vec4(0.0); }

    let alpha = clamp(timer / 2.0, 0.0, 1.0);
    let scale = 3u;
    let cw = 6u * scale;
    let cx = width / 2u;

    // "HOSTILES AHEAD" centered near top
    let line1_chars = 14u;
    let line1_w = line1_chars * cw;
    let tx1 = cx - line1_w / 2u;
    let ty1 = height / 5u;
    let alert_color = vec4(1.0, 0.6, 0.1, alpha);

    // H-O-S-t-I-L-E-S  A-H-E-A-d
    if (draw_letter_s(px, py, tx1, ty1, 7, scale)) { return alert_color; }                   // H
    if (draw_letter_s(px, py, tx1 + cw, ty1, 14, scale)) { return alert_color; }             // O
    if (draw_letter_s(px, py, tx1 + cw * 2u, ty1, 18, scale)) { return alert_color; }        // S
    if (draw_letter_s(px, py, tx1 + cw * 3u, ty1, 19, scale)) { return alert_color; }        // t
    if (draw_letter_s(px, py, tx1 + cw * 4u, ty1, 8, scale)) { return alert_color; }         // I
    if (draw_letter_s(px, py, tx1 + cw * 5u, ty1, 11, scale)) { return alert_color; }        // L
    if (draw_letter_s(px, py, tx1 + cw * 6u, ty1, 4, scale)) { return alert_color; }         // E
    if (draw_letter_s(px, py, tx1 + cw * 7u, ty1, 18, scale)) { return alert_color; }        // S
    // gap
    if (draw_letter_s(px, py, tx1 + cw * 9u, ty1, 0, scale)) { return alert_color; }         // A
    if (draw_letter_s(px, py, tx1 + cw * 10u, ty1, 7, scale)) { return alert_color; }        // H
    if (draw_letter_s(px, py, tx1 + cw * 11u, ty1, 4, scale)) { return alert_color; }        // E
    if (draw_letter_s(px, py, tx1 + cw * 12u, ty1, 0, scale)) { return alert_color; }        // A
    if (draw_letter_s(px, py, tx1 + cw * 13u, ty1, 3, scale)) { return alert_color; }        // d

    // "WASD  FIRE" on second line
    let line2_chars = 10u;
    let line2_w = line2_chars * cw;
    let tx2 = cx - line2_w / 2u;
    let ty2 = ty1 + 28u;
    let ctrl_color = vec4(0.5, 0.9, 1.0, alpha * 0.8);

    // W-A-S-D  F-I-R-E
    if (draw_letter_s(px, py, tx2, ty2, 22, scale)) { return ctrl_color; }                   // W
    if (draw_letter_s(px, py, tx2 + cw, ty2, 0, scale)) { return ctrl_color; }               // A
    if (draw_letter_s(px, py, tx2 + cw * 2u, ty2, 18, scale)) { return ctrl_color; }         // S
    if (draw_letter_s(px, py, tx2 + cw * 3u, ty2, 3, scale)) { return ctrl_color; }          // D
    // gap
    if (draw_letter_s(px, py, tx2 + cw * 5u, ty2, 5, scale)) { return ctrl_color; }          // F
    if (draw_letter_s(px, py, tx2 + cw * 6u, ty2, 8, scale)) { return ctrl_color; }          // I
    if (draw_letter_s(px, py, tx2 + cw * 7u, ty2, 17, scale)) { return ctrl_color; }         // R
    if (draw_letter_s(px, py, tx2 + cw * 8u, ty2, 4, scale)) { return ctrl_color; }          // E

    return vec4(0.0);
}

fn draw_quest_panel(px: u32, py: u32, width: u32) -> vec4<f32> {
    let qid = i32(hud.quest_id);
    if (qid == 0) { return vec4(0.0); }

    let panel_w = 300u;
    let panel_h = 80u;
    let panel_x = width - panel_w - 16u;
    let panel_y = 56u;

    if (px < panel_x || px >= panel_x + panel_w || py < panel_y || py >= panel_y + panel_h) {
        return vec4(0.0);
    }

    let bg = vec4(0.0, 0.05, 0.15, 0.6);
    let scale = 3u;
    let cw = 6u * scale;
    let ty = panel_y + 6u;
    let tx = panel_x + 8u;
    let title_color = vec4(0.4, 0.8, 1.0, 1.0);
    let prog_color = vec4(0.3, 1.0, 0.5, 1.0);

    // Quest 1: "BREACH" / Quest 2: "CLEAR" / Quest 3: "INTEL" / Quest 4: "REACTOR"
    if (qid == 1) {
        // OBJ (objective label)
        if (draw_letter_s(px, py, tx, ty, 14, scale)) { return title_color; }           // O
        if (draw_letter_s(px, py, tx + cw, ty, 1, scale)) { return title_color; }       // B
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 9, scale)) { return title_color; }  // J
    } else if (qid == 2) {
        // CLEAR + kill count
        if (draw_letter_s(px, py, tx, ty, 2, scale)) { return title_color; }             // C
        if (draw_letter_s(px, py, tx + cw, ty, 11, scale)) { return title_color; }      // L
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 17, scale)) { return title_color; } // r
    } else if (qid == 3) {
        // INTEL
        if (draw_letter_s(px, py, tx, ty, 8, scale)) { return title_color; }             // I
        if (draw_letter_s(px, py, tx + cw, ty, 13, scale)) { return title_color; }      // N
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 19, scale)) { return title_color; } // t
    } else if (qid == 4) {
        // CORE
        if (draw_letter_s(px, py, tx, ty, 2, scale)) { return title_color; }             // C
        if (draw_letter_s(px, py, tx + cw, ty, 14, scale)) { return title_color; }      // O
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 17, scale)) { return title_color; } // r
        if (draw_letter_s(px, py, tx + cw * 3u, ty, 4, scale)) { return title_color; }  // E
    } else if (qid == 5) {
        // MEdS (Medic Supplies)
        if (draw_letter_s(px, py, tx, ty, 12, scale)) { return title_color; }            // M
        if (draw_letter_s(px, py, tx + cw, ty, 4, scale)) { return title_color; }       // E
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 3, scale)) { return title_color; }  // d
        if (draw_letter_s(px, py, tx + cw * 3u, ty, 18, scale)) { return title_color; } // S
    } else if (qid == 6) {
        // HULL (Engineer Repairs)
        if (draw_letter_s(px, py, tx, ty, 7, scale)) { return title_color; }             // H
        if (draw_letter_s(px, py, tx + cw, ty, 20, scale)) { return title_color; }      // U
        if (draw_letter_s(px, py, tx + cw * 2u, ty, 11, scale)) { return title_color; } // L
        if (draw_letter_s(px, py, tx + cw * 3u, ty, 11, scale)) { return title_color; } // L
    }

    // Progress: current / target
    let py2 = ty + 24u;
    if (draw_number_s(px, py, tx, py2, hud.quest_progress, 2, 0, scale)) { return prog_color; }
    // Slash
    let sx = tx + cw * 3u;
    if (px >= sx && px < sx + 2u * scale && py >= py2 && py < py2 + 7u * scale) {
        let lx = (px - sx) / scale;
        let ly = (py - py2) / scale;
        if (lx + ly >= 5u && lx + ly <= 7u) { return prog_color; }
    }
    if (draw_number_s(px, py, sx + cw, py2, hud.quest_target, 2, 0, scale)) { return prog_color; }

    return bg;
}

fn draw_death_overlay(px: u32, py: u32, width: u32, height: u32) -> vec4<f32> {
    if (hud.death_timer <= 0.0) { return vec4(0.0); }

    let cx = width / 2u;
    let cy = height / 2u;
    let scale = 4u;
    let cw = 6u * scale;
    let tx = cx - cw * 3u;
    let ty = cy - 20u;

    let pulse = 0.6 + sin(hud.death_timer * 4.0) * 0.2;
    let text_color = vec4(1.0, 0.15, 0.1, pulse);

    // "DEAD" centered on screen
    if (draw_letter_s(px, py, tx, ty, 3, scale)) { return text_color; }               // d
    if (draw_letter_s(px, py, tx + cw, ty, 4, scale)) { return text_color; }          // E
    if (draw_letter_s(px, py, tx + cw * 2u, ty, 0, scale)) { return text_color; }    // A
    if (draw_letter_s(px, py, tx + cw * 3u, ty, 3, scale)) { return text_color; }    // d

    // Countdown number below
    let ny = ty + 40u;
    let nx = cx - cw;
    if (draw_number_s(px, py, nx, ny, hud.death_timer, 1, 1, scale)) { return vec4(0.8, 0.8, 0.8, 0.9); }

    return vec4(0.0);
}

fn draw_minimap(px: u32, py: u32, width: u32, height: u32) -> vec4<f32> {
    let map_radius = 60u;
    let map_cx = map_radius + 20u;
    let map_cy = height - map_radius - 80u;

    let dx = i32(px) - i32(map_cx);
    let dy = i32(py) - i32(map_cy);
    let dist_sq = dx * dx + dy * dy;
    let r = i32(map_radius);

    if (dist_sq > r * r) { return vec4(0.0); }

    let dist = sqrt(f32(dist_sq));
    let edge_fade = 1.0 - smoothstep(f32(map_radius - 3u), f32(map_radius), dist);

    if (dist > f32(map_radius - 3u) && dist <= f32(map_radius)) {
        return vec4(0.0, 0.6, 0.8, edge_fade * 0.8);
    }

    let player_x = minimap_data[0];
    let player_z = minimap_data[1];
    let player_yaw = minimap_data[2];
    let enemy_count = u32(minimap_data[3]);
    let world_size = minimap_data[4];

    let scale = f32(map_radius) / (world_size * 0.6);
    let cos_yaw = cos(player_yaw);
    let sin_yaw = sin(player_yaw);

    for (var i = 0u; i < min(enemy_count, 24u); i++) {
        let ex = minimap_data[8u + i * 2u];
        let ez = minimap_data[9u + i * 2u];
        let rel_x = ex - player_x;
        let rel_z = ez - player_z;
        let rot_x = rel_x * cos_yaw + rel_z * sin_yaw;
        let rot_z = -rel_x * sin_yaw + rel_z * cos_yaw;
        let map_ex = i32(f32(map_cx) + rot_x * scale);
        let map_ey = i32(f32(map_cy) + rot_z * scale);
        let edx = i32(px) - map_ex;
        let edy = i32(py) - map_ey;
        if (edx * edx + edy * edy < 9) {
            return vec4(1.0, 0.2, 0.2, 0.9);
        }
    }

    let pdx = i32(px) - i32(map_cx);
    let pdy = i32(py) - i32(map_cy);
    if (abs(pdx) <= 3 && pdy >= -5 && pdy <= 3) {
        if (pdy <= -abs(pdx)) {
            return vec4(0.0, 1.0, 0.5, 1.0);
        }
    }

    return vec4(0.0, 0.02, 0.05, 0.4);
}

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    let width = screen_size.x;
    let height = screen_size.y;
    if (id.x >= width || id.y >= height) { return; }

    let pixel_idx = id.y * width + id.x;
    let mut color = framebuffer[pixel_idx];

    let cx = width / 2u;
    let cy = height / 2u;

    // Crosshair with hit marker (hidden on title screen)
    if (minimap_data[367] < 0.5) {
        let ch = draw_crosshair(id.x, id.y, cx, cy, hud.crosshair_size, hud.crosshair_hit);
        if (ch.a > 0.0) {
            color = vec4(mix(color.rgb, ch.rgb, ch.a), 1.0);
        }
    }

    // Target enemy health bar (below crosshair when aiming at an enemy)
    if (hud.target_visible > 0.0 && hud.target_max_health > 0.0) {
        let t_frac = clamp(hud.target_health / hud.target_max_health, 0.0, 1.0);
        let bar_w = 60u;
        let bar_h = 4u;
        let bar_x = cx - bar_w / 2u;
        let bar_y = cy + 25u;
        if (id.x >= bar_x && id.x < bar_x + bar_w && id.y >= bar_y && id.y < bar_y + bar_h) {
            let fill_end = bar_x + u32(f32(bar_w) * t_frac);
            if (id.x < fill_end) {
                var tc = vec3(0.2, 0.9, 0.2);
                if (t_frac < 0.5) { tc = vec3(1.0, 0.7, 0.15); }
                if (t_frac < 0.25) { tc = vec3(1.0, 0.2, 0.15); }
                color = vec4(tc, 1.0);
            } else {
                color = vec4(0.15, 0.15, 0.15, 0.6);
            }
        }
        // Alert indicator dot above the bar
        if (hud.target_alert > 0.0) {
            let dot_x = i32(id.x) - i32(cx);
            let dot_y = i32(id.y) - i32(bar_y - 8u);
            if (dot_x * dot_x + dot_y * dot_y < 9) {
                var ac = vec3(1.0, 1.0, 0.3);
                if (hud.target_alert > 1.5) { ac = vec3(1.0, 0.3, 0.2); }
                color = vec4(ac, 1.0);
            }
        }
    }

    // Health bar
    let health_pct = clamp(hud.health / hud.max_health, 0.0, 1.0);
    let hb = draw_health_bar(id.x, id.y, width, height, health_pct);
    if (hb.a > 0.0) {
        color = vec4(mix(color.rgb, hb.rgb, hb.a), 1.0);
    }

    // Energy bar
    let energy_pct = clamp(hud.energy / hud.max_energy, 0.0, 1.0);
    let eb = draw_energy_bar(id.x, id.y, width, height, energy_pct);
    if (eb.a > 0.0) {
        color = vec4(mix(color.rgb, eb.rgb, eb.a), 1.0);
    }

    // Ammo bar
    let ammo_pct = clamp(hud.ammo / hud.max_ammo, 0.0, 1.0);
    let ab = draw_ammo_bar(id.x, id.y, width, height, ammo_pct);
    if (ab.a > 0.0) {
        color = vec4(mix(color.rgb, ab.rgb, ab.a), 1.0);
    }

    // Damage flash
    let dmg = draw_damage_flash(id.x, id.y, width, height, hud.damage_flash);
    if (dmg.a > 0.0) {
        color = vec4(mix(color.rgb, dmg.rgb, dmg.a), 1.0);
    }

    // Damage direction indicator
    let ddir = draw_damage_direction(id.x, id.y, width, height, hud.damage_indicator_angle, hud.damage_indicator_alpha);
    if (ddir.a > 0.0) {
        color = vec4(mix(color.rgb, ddir.rgb, ddir.a), 1.0);
    }

    // NPC interaction prompt (simplified - text rendering was too complex for Metal compiler)
    if (hud.npc_prompt_active >= 0.5) {
        let prompt_cx = width / 2u;
        let prompt_cy = height / 2u + 40u;
        let prompt_dx = abs(i32(id.x) - i32(prompt_cx));
        let prompt_dy = abs(i32(id.y) - i32(prompt_cy));
        if (prompt_dx < 100 && prompt_dy < 14) {
            if (prompt_dx < 98 && prompt_dy < 12) {
                color = vec4(mix(color.rgb, vec3(0.0, 0.05, 0.15), 0.7), 1.0);
            } else {
                color = vec4(mix(color.rgb, vec3(0.4, 0.9, 1.0), 0.8), 1.0);
            }
            if (draw_char_s(id.x, id.y, prompt_cx - 84u, prompt_cy - 8u, 5, 2u)) {
                color = vec4(1.0, 0.8, 0.2, 1.0);
            }
        }
    }

    // Notification popup (simplified)
    if (hud.notify_timer > 0.0) {
        let notify_alpha = clamp(hud.notify_timer / 0.5, 0.0, 1.0);
        let notify_cy = height - 100u;
        let notify_dx = abs(i32(id.x) - i32(width / 2u));
        let notify_dy = abs(i32(id.y) - i32(notify_cy));
        if (notify_dx < 150 && notify_dy < 16) {
            let ntype = i32(hud.notify_type);
            var nc = vec3(0.3, 0.9, 1.0);
            if (ntype == 2) { nc = vec3(0.2, 1.0, 0.4); }
            if (ntype == 3) { nc = vec3(1.0, 0.85, 0.2); }
            if (ntype == 4) { nc = vec3(1.0, 0.9, 0.3); }
            if (ntype == 5) { nc = vec3(1.0, 0.25, 0.15); }
            if (ntype == 6) { nc = vec3(0.4, 1.0, 0.7); }
            color = vec4(mix(color.rgb, nc, notify_alpha * 0.6), 1.0);
        }
    }

    // Dialog box (speaker portrait + text + choices)
    if (hud.dialog_active >= 0.5) {
        let dbox_w = min(width - 40u, 800u);
        let dbox_h = 160u;
        let dbox_x = (width - dbox_w) / 2u;
        let dbox_y = 20u;
        let text_indent = 88u;
        if (id.x >= dbox_x && id.x < dbox_x + dbox_w && id.y >= dbox_y && id.y < dbox_y + dbox_h) {
            let drel_x = id.x - dbox_x;
            let drel_y = id.y - dbox_y;
            if (drel_x < 2u || drel_x >= dbox_w - 2u || drel_y < 2u || drel_y >= dbox_h - 2u) {
                color = vec4(0.2, 0.6, 0.9, 0.9);
            } else if (drel_y < 24u) {
                color = vec4(mix(color.rgb, vec3(0.1, 0.2, 0.35), 0.95), 1.0);
                let speaker_len = u32(minimap_data[64]);
                let dcw = 12u;
                var dci = 0u;
                while (dci < speaker_len && dci < 16u) {
                    let dcc = i32(minimap_data[65u + dci]);
                    if (draw_char_s(id.x, id.y, dbox_x + text_indent + dci * dcw, dbox_y + 4u, dcc, 2u)) {
                        color = vec4(0.4, 0.85, 1.0, 1.0);
                    }
                    dci = dci + 1u;
                }
            } else {
                color = vec4(mix(color.rgb, vec3(0.02, 0.04, 0.10), 0.88), 1.0);
                let text_len = u32(minimap_data[81]);
                let dtcw = 12u;
                let dtch = 16u;
                let chars_line = (dbox_w - text_indent - 24u) / dtcw;
                var dti = 0u;
                while (dti < text_len && dti < 64u) {
                    let dline = dti / chars_line;
                    let dcol = dti % chars_line;
                    let dtx = dbox_x + text_indent + dcol * dtcw;
                    let dty = dbox_y + 32u + dline * dtch;
                    if (dty + dtch > dbox_y + dbox_h - 28u) { break; }
                    let dtcc = i32(minimap_data[82u + dti]);
                    if (draw_char_s(id.x, id.y, dtx, dty, dtcc, 2u)) {
                        color = vec4(0.85, 0.88, 0.92, 1.0);
                    }
                    dti = dti + 1u;
                }
                // Choice rows at bottom
                let choice_count = u32(hud.dialog_choice_count + 0.5);
                let selected = u32(hud.dialog_selected_choice + 0.5);
                var ci = 0u;
                while ci < choice_count && ci < 3u {
                    let cy = dbox_y + dbox_h - 24u - (choice_count - ci) * 18u;
                    let highlight = ci == selected;
                    if (id.y >= cy && id.y < cy + 16u && id.x >= dbox_x + text_indent && id.x < dbox_x + dbox_w - 12u) {
                        if (highlight) {
                            color = vec4(mix(color.rgb, vec3(0.15, 0.45, 0.75), 0.85), 1.0);
                        }
                    }
                    ci = ci + 1u;
                }
            }
        }
        let portrait = draw_dialog_portrait(id.x, id.y, dbox_x, dbox_y, dbox_h);
        if (portrait.a > 0.0) {
            color = vec4(mix(color.rgb, portrait.rgb, portrait.a), 1.0);
        }
    }

    // Minimap (hidden when full map overlay open)
    if (minimap_data[372] < 0.5) {
        let mm = draw_minimap(id.x, id.y, width, height);
        if (mm.a > 0.0) {
            color = vec4(mix(color.rgb, mm.rgb, mm.a), 1.0);
        }
    }

    // Performance metrics panel (top-right, F3 / grave)
    let metrics = draw_metrics_panel(id.x, id.y, width);
    if (metrics.a > 0.0) {
        color = vec4(mix(color.rgb, metrics.rgb, metrics.a), 1.0);
    }

    // Debug panel
    let dbg = draw_debug_panel(id.x, id.y, width);
    if (dbg.a > 0.0) {
        color = vec4(mix(color.rgb, dbg.rgb, dbg.a), 1.0);
    }

    // Level indicator
    let lv = draw_level_indicator(id.x, id.y, width);
    if (lv.a > 0.0) {
        color = vec4(mix(color.rgb, lv.rgb, lv.a), 1.0);
    }

    // Inventory indicator
    let inv = draw_inventory_indicator(id.x, id.y, width, height);
    if (inv.a > 0.0) {
        color = vec4(mix(color.rgb, inv.rgb, inv.a), 1.0);
    }

    // Quest panel
    let qp = draw_quest_panel(id.x, id.y, width);
    if (qp.a > 0.0) {
        color = vec4(mix(color.rgb, qp.rgb, qp.a), 1.0);
    }

    // Onboarding hint overlay (top-center banner with current tutorial step)
    // Buffer layout: minimap_data[320] = hint length, [321..360] = hint chars (40 max), [361] = obj distance
    let onboard_len = u32(minimap_data[320]);
    if (onboard_len > 0u && onboard_len <= 40u) {
        let ob_char_w = 14u;
        let ob_text_w = onboard_len * ob_char_w;
        let ob_pad = 20u;
        let ob_box_w = ob_text_w + ob_pad * 2u;
        let ob_box_h = 36u;
        let ob_box_x = (width - ob_box_w) / 2u;
        let ob_box_y = 40u;
        if (id.x >= ob_box_x && id.x < ob_box_x + ob_box_w && id.y >= ob_box_y && id.y < ob_box_y + ob_box_h) {
            let ob_rx = id.x - ob_box_x;
            let ob_ry = id.y - ob_box_y;
            if (ob_rx < 2u || ob_rx >= ob_box_w - 2u || ob_ry < 2u || ob_ry >= ob_box_h - 2u) {
                color = vec4(0.3, 0.85, 0.55, 0.9);
            } else {
                color = vec4(mix(color.rgb, vec3(0.02, 0.08, 0.04), 0.85), 1.0);
            }
            let ob_text_x = ob_box_x + ob_pad;
            let ob_text_y = ob_box_y + 8u;
            var ob_ci = 0u;
            while (ob_ci < onboard_len && ob_ci < 40u) {
                let ob_cc = i32(minimap_data[321u + ob_ci]);
                if (draw_char_s(id.x, id.y, ob_text_x + ob_ci * ob_char_w, ob_text_y, ob_cc, 3u)) {
                    color = vec4(0.85, 1.0, 0.85, 1.0);
                }
                ob_ci = ob_ci + 1u;
            }
        }

        // Objective distance below the hint box
        let obj_dist = minimap_data[361];
        if (obj_dist > 0.0) {
            let obj_dist_text_y = 80u;
            let dist_str_x = width / 2u - 40u;
            let dist_int = u32(obj_dist);
            let d100 = dist_int / 100u;
            let d10 = (dist_int % 100u) / 10u;
            let d1 = dist_int % 10u;
            if (d100 > 0u) {
                if (draw_char_s(id.x, id.y, dist_str_x, obj_dist_text_y, i32(d100 + 26u), 2u)) {
                    color = vec4(0.7, 0.95, 0.7, 1.0);
                }
            }
            if (d100 > 0u || d10 > 0u) {
                if (draw_char_s(id.x, id.y, dist_str_x + 12u, obj_dist_text_y, i32(d10 + 26u), 2u)) {
                    color = vec4(0.7, 0.95, 0.7, 1.0);
                }
            }
            if (draw_char_s(id.x, id.y, dist_str_x + 24u, obj_dist_text_y, i32(d1 + 26u), 2u)) {
                color = vec4(0.7, 0.95, 0.7, 1.0);
            }
            if (draw_char_s(id.x, id.y, dist_str_x + 36u, obj_dist_text_y, 12, 2u)) {
                color = vec4(0.5, 0.8, 0.5, 1.0);
            }
        }
    }

}
