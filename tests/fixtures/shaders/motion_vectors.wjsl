// Motion vector pass — required dependency for temporal AA (pit of success).

use "wjsl_std/gpu_types_generated.wjsl"
use "wjsl_std/gbuffer.wjsl"

@group(0) @binding(0) uniform params: MotionVectorParams;
@group(0) @binding(1) storage read gbuffer: array<GBufferPixel>;
@group(0) @binding(2) storage read_write motion_buffer: array<vec4<f32>>;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= params.width || id.y >= params.height) { return; }
    let idx = id.y * params.width + id.x;
    let gbuf = gbuffer[idx];
    let depth = gbuf.depth;
    let jitter_delta = vec2(params.jitter_x - params.prev_jitter_x, params.jitter_y - params.prev_jitter_y);
    let velocity = jitter_delta * (1.0 - depth * 0.001);
    motion_buffer[idx] = vec4(velocity, depth, 1.0);
}
