// Test Shader - Solid MAGENTA (WJSL)
//
// Minimal shader to test WJSL→WGSL transpilation pipeline.
// Should output solid MAGENTA color to all pixels.

@group(0) @binding(0) uniform screen_size: vec2<u32>;
@group(0) @binding(1) storage read_write output: array<vec4<f32> >;

@compute @workgroup_size(8, 8, 1)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= screen_size.x || id.y >= screen_size.y) { return; }
    let pixel_idx = id.y * screen_size.x + id.x;
    output[pixel_idx] = vec4(1.0, 0.0, 1.0, 1.0); // MAGENTA
}
