struct Foo {
    value: int,
}

impl Foo {
    fn new() -> Foo {
        Foo { value: 0 }
    }
    
    // Owned self - should auto-generate as mut self
    fn consume(self) {
        println!("Consuming {}", self.value)
    }
    
    // Borrowed mut self - explicit
    fn increment(&mut self) {
        self.value += 1
    }
}

// Owned parameter - should auto-generate as mut
fn process(data: Vec<int>) {
    data.push(42)
    println!("Processed: {:?}", data)
}

fn main() {
    let mut foo = Foo::new()
    foo.increment()
    foo.consume()
    
    let v = vec![1, 2, 3]
    process(v)
}


