// ServerResponse - Build Responses

impl ServerResponse {
    fn new(status: int, body: string) -> ServerResponse {
        ServerResponse {
            status: status,
            headers: vec![],
            body: body,
            binary_body: None,
        }
    }

    fn ok(body: string) -> ServerResponse {
        ServerResponse {
            status: 200,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn json(body: string) -> ServerResponse {
        ServerResponse {
            status: 200,
            headers: vec![("Content-Type", "application/json")],
            body: body,
            binary_body: None,
        }
    }

    fn json_value<T>(data: T) -> ServerResponse {
        ServerResponse {
            status: 200,
            body: "",
            headers: vec![("Content-Type", "application/json")],
            binary_body: None,
        }
    }
    
    fn created(body: string) -> ServerResponse {
        ServerResponse {
            status: 201,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn no_content() -> ServerResponse {
        ServerResponse {
            status: 204,
            body: "",
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn bad_request(body: string) -> ServerResponse {
        ServerResponse {
            status: 400,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn unauthorized(body: string) -> ServerResponse {
        ServerResponse {
            status: 401,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn forbidden(body: string) -> ServerResponse {
        ServerResponse {
            status: 403,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn not_found() -> ServerResponse {
        ServerResponse {
            status: 404,
            body: "Not Found",
            headers: vec![],
            binary_body: None,
        }
    }

    fn error(status: int, message: string) -> ServerResponse {
        ServerResponse {
            status: status,
            headers: vec![("Content-Type", "text/plain")],
            body: message,
            binary_body: None,
        }
    }

    fn binary(status: int, data: Vec<u8>) -> ServerResponse {
        ServerResponse {
            status: status,
            headers: vec![],
            body: "",
            binary_body: Some(data),
        }
    }

    fn html(body: string) -> ServerResponse {
        ServerResponse {
            status: 200,
            headers: vec![("Content-Type", "text/html")],
            body: body,
            binary_body: None,
        }
    }
    
    fn internal_error(body: string) -> ServerResponse {
        ServerResponse {
            status: 500,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn with_status(status: int, body: string) -> ServerResponse {
        ServerResponse {
            status: status,
            body: body,
            headers: vec![],
            binary_body: None,
        }
    }
    
    fn with_header(self, key: string, value: string) -> ServerResponse {
        self
    }

    fn header(self, key: string, value: string) -> ServerResponse {
        self
    }
}

// Simple server (catch-all handler) — sync API, no @async main required.
// Implementation: windjammer_runtime::http (axum + tokio block_on, hidden from users)

struct ServerRequest {
    method: string,
    path: string,
    query: HashMap<string, string>,
    headers: Vec<(string, string)>,
    body: string,
}

impl ServerRequest {
    /// Single query parameter lookup (maps to runtime `query_param`).
    fn query(self, key: string) -> Option<string> {
        None
    }

    /// Header lookup (maps to runtime `header`, case-insensitive).
    fn header(self, key: string) -> Option<string> {
        None
    }
}

struct Server {
    address: string,
    port: int,
}

impl Server {
    fn new(address: string, port: int) -> Server {
        Server {
            address: address,
            port: port,
        }
    }

    /// Blocking server — runs until error or shutdown. Handler receives each request.
    fn serve(self, handler: fn(ServerRequest) -> ServerResponse) -> Result<(), string> {
        server_serve(self.address, self.port, handler)
    }
}

/// Low-level entry: bound address + port + catch-all handler (maps to runtime).
fn server_serve(address: string, port: int, handler: fn(ServerRequest) -> ServerResponse) -> Result<(), string> {
    Err("use std::http import — maps to windjammer_runtime::http::server_serve")
}

