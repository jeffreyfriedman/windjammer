# Rust artifacts
/target
**/*.rs.bk
*.pdb

# Test artifacts (prevent pollution)
/*.rlib
/*.rmeta
**/*.rlib
**/*.rs.map
/*.so
/*.dylib
/*.dll

# Integration test scratch output (regenerated at test runtime)
tests/generated/

# Windjammer artifacts
/build
/test_output_*
.wj-cache/
.wj-compiler-stamp

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local issue tracking (bd/beads — per-clone, not shared in git)
.beads/

# Generated Rust files in stdlib
std/**/*.rs
!std/**/lib.rs
